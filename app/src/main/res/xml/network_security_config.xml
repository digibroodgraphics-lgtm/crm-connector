<?xml version="1.0" encoding="utf-8"?>
<!--
    Security requirement: HTTPS ONLY.
    Cleartext (HTTP) traffic is disabled application-wide. Any attempt to talk to
    an http:// endpoint will be blocked by the platform. The app additionally
    rejects http:// URLs in code (see UrlValidator).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
